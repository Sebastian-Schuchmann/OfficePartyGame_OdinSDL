# Simple unit cube centered at origin
# 8 vertices, 6 faces (12 triangles as quads), CCW winding

v  0.5  0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5  0.5
v  0.5 -0.5  0.5
v -0.5  0.5 -0.5
v -0.5 -0.5 -0.5
v -0.5  0.5  0.5
v -0.5 -0.5  0.5

vn  1  0  0
vn -1  0  0
vn  0  1  0
vn  0 -1  0
vn  0  0  1
vn  0  0 -1

# Right face (+X)
f 1//1 2//1 4//1
f 1//1 4//1 3//1

# Left face (-X)
f 5//2 7//2 8//2
f 5//2 8//2 6//2

# Top face (+Y)
f 1//3 3//3 7//3
f 1//3 7//3 5//3

# Bottom face (-Y)
f 2//4 6//4 8//4
f 2//4 8//4 4//4

# Front face (+Z)
f 3//5 4//5 8//5
f 3//5 8//5 7//5

# Back face (-Z)
f 1//6 5//6 6//6
f 1//6 6//6 2//6
